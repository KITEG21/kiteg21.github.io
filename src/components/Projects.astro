---
import ProjectCard from './ProjectCard.astro';
import projectsData from '../data/projects.json';

const projects = projectsData.projects;
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-dark-bg">
	<div class="max-w-6xl mx-auto">
		<!-- Section header -->
		<div class="mb-16 space-y-4 animate-slide-up">
			<h2 class="text-4xl sm:text-5xl font-black">
				Featured
				<span class="text-accent"> Projects</span>
			</h2>
			<p class="text-text-secondary text-lg max-w-2xl">
				A selection of systems I've engineered. Each represents deep focus on scalability, reliability, and architectural clarity.
			</p>
		</div>

		<!-- Projects grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
			{
				projects.map((project, index) => (
					<div style={{ animationDelay: `${index * 100}ms` }} class="animate-slide-up">
						<a href={`/projects/${project.slug}`} class="block no-underline">
							<ProjectCard {...project} />
						</a>
					</div>
				))
			}
		</div>

		<!-- Explore more -->
		<div class="mt-16 text-center">
			<a
				href="https://github.com/KITEG21?tab=repositories"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-block text-accent hover:text-accent-hover transition-colors duration-250"
			>
				View all projects →
			</a>
		</div>
	</div>
</section>

<style>
	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	div[style] {
		animation: slideUp 0.6s ease-out forwards;
		opacity: 0;
	}
</style>
