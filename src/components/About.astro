---
interface Props {
	about: {
		title1: string;
		title2: string;
		paragraphs: readonly string[];
		stats: {
			years: string;
			delivered: string;
			languages: string;
			learn: string;
		};
		skillsTitle: string;
	};
}

const { about } = Astro.props;
---

<section id="about" class="py-20 px-4 sm:px-6 lg:px-8 bg-dark-bg">
	<div class="max-w-4xl mx-auto space-y-12">
		<!-- Section header -->
		<div class="space-y-4 animate-slide-up">
			<h2 class="text-4xl sm:text-5xl font-black">
				{about.title1}
				<span class="text-accent"> {about.title2}</span>
			</h2>
		</div>

		<!-- Content -->
		<div class="prose prose-invert max-w-none space-y-6 animate-slide-up" style={{ animationDelay: '100ms' }}>
			{about.paragraphs.map((paragraph) => (
				<p class="text-text-secondary text-lg leading-relaxed">{paragraph}</p>
			))}

			<!-- Quick stats -->
			<div class="grid grid-cols-2 sm:grid-cols-4 gap-6 pt-8">
				<div class="border-l-2 border-accent pl-4">
					<div class="text-2xl font-black text-accent">3+</div>
					<div class="text-sm text-text-secondary">{about.stats.years}</div>
				</div>
				<div class="border-l-2 border-accent pl-4">
					<div class="text-2xl font-black text-accent">25+</div>
					<div class="text-sm text-text-secondary">{about.stats.delivered}</div>
				</div>
				<div class="border-l-2 border-accent pl-4">
					<div class="text-2xl font-black text-accent">5+</div>
					<div class="text-sm text-text-secondary">{about.stats.languages}</div>
				</div>
				<div class="border-l-2 border-accent pl-4">
					<div class="text-2xl font-black text-accent">∞</div>
					<div class="text-sm text-text-secondary">{about.stats.learn}</div>
				</div>
			</div>

			<!-- Skills -->
			<div class="pt-8">
				<h3 class="text-lg font-bold mb-4">{about.skillsTitle}</h3>
				<div class="flex flex-wrap gap-2">
					{
						[
							'Backend Architecture',
							'Distributed Systems',
							'Database Design',
                            '.NET',
							'Go',
							'TypeScript',
							'Python',
							'PostgreSQL',
							'Microservices',
							'API Design',
							'Performance Optimization',
						].map((skill) => (
							<span class="px-4 py-2 bg-border text-text-secondary text-sm rounded border border-border/50 hover:border-accent/50 hover:text-accent transition-all duration-250">
								{skill}
							</span>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-slide-up {
		animation: slideUp 0.6s ease-out forwards;
		opacity: 0;
	}

	.prose-invert {
		--prose-body: rgba(255, 255, 255, 0.8);
		--prose-headings: rgba(255, 255, 255, 1);
		--prose-links: rgb(79, 70, 229);
	}
</style>
