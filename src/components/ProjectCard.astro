---
export interface Props {
	name: string;
	// allow string statuses from JSON imports; specific components map colors
	status: string;
	description: string;
	techStack: Array<string>;
	github?: string;
	demo?: string;
	icon?: string;
}

const { name, status, description, techStack, github, demo, icon } = Astro.props;

const statusColors: Record<string, string> = {
	ACTIVE: 'bg-green-500/10 border-green-500/30 text-green-400',
	DEVELOPMENT: 'bg-blue-500/10 border-blue-500/30 text-blue-400',
	LEARNING: 'bg-yellow-500/10 border-yellow-500/30 text-yellow-400',
	EXPERIMENTAL: 'bg-purple-500/10 border-purple-500/30 text-purple-400',
};
---

<div
	class="group relative p-6 sm:p-8 border border-border rounded-lg hover:border-accent/50 transition-all duration-350 hover:shadow-lg hover:shadow-accent/10 bg-dark-bg/50 backdrop-blur-sm hover:bg-dark-bg/80 cursor-pointer"
>
	<!-- Accent line on hover -->
	<div
		class="absolute top-0 left-0 h-1 bg-gradient-to-r from-accent to-transparent rounded-t-lg w-0 group-hover:w-12 transition-all duration-350"
	></div>

	<!-- Header -->
	<div class="flex items-start justify-between mb-4">
		<div class="flex-1">
			<h3 class="text-xl sm:text-2xl font-bold text-text-primary group-hover:text-accent transition-colors duration-250">
				{icon && <span class="mr-2">{icon}</span>}
				{name}
			</h3>
		</div>
		<span class={`text-xs font-mono font-bold uppercase px-3 py-1 rounded border whitespace-nowrap ml-4 ${statusColors[status]}`}>
			{status}
		</span>
	</div>

	<!-- Description -->
	<p class="text-text-secondary text-sm sm:text-base mb-4 leading-relaxed">
		{description}
	</p>

	<!-- Tech Stack -->
	<div class="flex flex-wrap gap-2 mb-6">
		{
			techStack.map((tech) => (
				<span class="text-xs font-mono px-3 py-1 bg-border text-text-secondary rounded border border-border/50 group-hover:border-accent/30 transition-colors duration-250">
					{tech}
				</span>
			))
		}
	</div>

	<!-- Links -->
	<div class="flex gap-3 pt-4 border-t border-border/50">
		{
			github && (
				<a
					href={github}
					target="_blank"
					rel="noopener noreferrer"
					class="text-text-secondary text-sm font-mono hover:text-accent transition-colors duration-250 hover:underline"
				>
					GitHub →
				</a>
			)
		}
		{
			demo && (
				<a
					href={demo}
					target="_blank"
					rel="noopener noreferrer"
					class="text-text-secondary text-sm font-mono hover:text-accent transition-colors duration-250 hover:underline"
				>
					Demo →
				</a>
			)
		}
	</div>
</div>
