---
import '../styles/global.css';
import { withLocalePath, type Locale } from '../i18n';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	locale?: Locale;
	copy: {
		nav: {
			projects: string;
			about: string;
			contact: string;
		};
		footer: string;
	};
}

const {
	title = 'Portfolio',
	description = 'Backend engineer, distributed systems, and AI',
	keywords = 'Gabriel Rodríguez Delgado, Gabriel Esteban Rodriguez Delgado, Gabriel Rodriguez, Gabriel rd, Gabriel.rd, backend engineer, distributed systems, AI, portfolio, software engineering',
	locale = 'en',
	copy,
} = Astro.props;
const siteUrl = Astro.site ?? '';
const basePath = withLocalePath('/', locale);
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(es|it)(?=\/|$)/, '') || '/';
const enPath = withLocalePath(pathWithoutLocale, 'en');
const esPath = withLocalePath(pathWithoutLocale, 'es');
const itPath = withLocalePath(pathWithoutLocale, 'it');
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content="index, follow" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/x-icon" href="/icon.ico" />
		<title>{title}</title>
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		{siteUrl && <meta property="og:url" content={siteUrl} />}
		<meta property="og:site_name" content="Gabriel.rd | Portfolio" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{siteUrl && <link rel="canonical" href={siteUrl} />}
		<style is:global>
			html {
				color-scheme: dark;
			}
		</style>
	</head>
	<body class="bg-dark-bg text-text-primary font-sans antialiased">
		<!-- Minimal navbar -->
		<nav class="fixed top-0 w-full z-50 bg-dark-bg/80 backdrop-blur-sm border-b border-border">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
				<a href={basePath} class="text-lg font-bold hover:text-accent transition-colors">
					&lt; /web &gt;
				</a>
				<div class="flex gap-2 text-xs font-mono sm:hidden">
					<a href={enPath} class={`px-2 py-1 rounded border ${locale === 'en' ? 'text-accent border-accent/50' : 'text-text-secondary border-border'}`}>EN</a>
					<a href={esPath} class={`px-2 py-1 rounded border ${locale === 'es' ? 'text-accent border-accent/50' : 'text-text-secondary border-border'}`}>ES</a>
					<a href={itPath} class={`px-2 py-1 rounded border ${locale === 'it' ? 'text-accent border-accent/50' : 'text-text-secondary border-border'}`}>IT</a>
				</div>
				<div class="hidden sm:flex gap-6 text-sm items-center">
					<a href={`${basePath}#projects`} class="hover:text-accent transition-colors">{copy.nav.projects}</a>
					<a href={`${basePath}#about`} class="hover:text-accent transition-colors">{copy.nav.about}</a>
					<a href={`${basePath}#contact`} class="hover:text-accent transition-colors">{copy.nav.contact}</a>
					<div class="flex gap-2 ml-2 text-xs font-mono">
						<a href={enPath} class={locale === 'en' ? 'text-accent' : 'text-text-secondary'}>EN</a>
						<a href={esPath} class={locale === 'es' ? 'text-accent' : 'text-text-secondary'}>ES</a>
						<a href={itPath} class={locale === 'it' ? 'text-accent' : 'text-text-secondary'}>IT</a>
					</div>
				</div>
			</div>
		</nav>

		<!-- Main content -->
		<main class="pt-16">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="py-12 border-t border-border mt-20 bg-dark-bg">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
				<p class="text-text-secondary text-sm text-center">{copy.footer}</p>
			</div>
		</footer>
	</body>
</html>

<style>
	body {
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
	}
</style>
