---
import projectsData from '../../data/projects.json';
import Layout from '../../layouts/Layout.astro';
import ProjectDetail from '../../components/ProjectDetail.astro';
import { copy } from '../../i18n';
import { localizeProject } from '../../data/projectTranslations';

export async function getStaticPaths() {
  return projectsData.projects.map((project) => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;
const project = projectsData.projects.find((p) => p.slug === slug);
const t = copy.en;

if (!project) {
  throw new Error(`Project not found: ${slug}`);
}

const localizedProject = localizeProject(project, 'en');
---

<Layout title={`${localizedProject.name} — Project`} locale="en" copy={t}>
  <ProjectDetail project={localizedProject} copy={t} locale="en" />
</Layout>
